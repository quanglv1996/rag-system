# =============================================================================
# Application
# =============================================================================
APP_NAME="AI Automation Platform"
APP_VERSION="1.0.0"
APP_ENV=development
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-characters-long

# =============================================================================
# API
# =============================================================================
API_V1_PREFIX=/api/v1

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_platform
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# =============================================================================
# OpenAI
# =============================================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Google AI
# =============================================================================
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-pro
GOOGLE_EMBEDDING_MODEL=models/embedding-001

# =============================================================================
# Provider Selection
# =============================================================================
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# =============================================================================
# Vector Database
# =============================================================================
VECTOR_DB=chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
FAISS_INDEX_PATH=./data/faiss

# =============================================================================
# Facebook
# =============================================================================
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_TOKEN=
FACEBOOK_VERIFY_TOKEN=
FACEBOOK_WEBHOOK_SECRET=
FACEBOOK_API_VERSION=v19.0

# =============================================================================
# TikTok
# =============================================================================
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/api/v1/tiktok/callback

# =============================================================================
# YouTube
# =============================================================================
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/youtube/callback

# =============================================================================
# Telegram
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# =============================================================================
# Security
# =============================================================================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# =============================================================================
# RAG
# =============================================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_TOP_K=5

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# HTTP Client
# =============================================================================
HTTP_TIMEOUT=30.0
HTTP_MAX_RETRIES=3

# =============================================================================
# Anthropic (Module 26)
# =============================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# =============================================================================
# Ollama Local LLM (Module 26)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# =============================================================================
# Storage Layer (Module 29)
# =============================================================================
STORAGE_BACKEND=local
STORAGE_BASE_PATH=./data/storage
# For S3/MinIO:
# S3_BUCKET=ai-platform
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin

# =============================================================================
# Monitoring (Module 31)
# =============================================================================
OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_ENABLED=true

# =============================================================================
# Notifications (Module 30)
# =============================================================================
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# =============================================================================
# Scheduler (Module 19)
# =============================================================================
SCHEDULER_ENABLED=true
TOKEN_REFRESH_CRON=0 */30 * * *

